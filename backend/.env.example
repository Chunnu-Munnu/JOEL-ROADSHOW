# TRINETRA Backend Configuration
# Copy this file to .env and update values

# Application
APP_NAME=TRINETRA
APP_VERSION=1.0.0
DEBUG=True
HOST=0.0.0.0
PORT=8000

# Database (Use SQLite for hackathon/demo, PostgreSQL for production)
# SQLite (Simple - No installation needed):
DATABASE_URL=sqlite+aiosqlite:///./trinetra.db

# PostgreSQL (Production):
# DATABASE_URL=postgresql+asyncpg://trinetra:secure_password@localhost:5432/trinetra_db

# Redis (Optional - for production scaling)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-this-to-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# YOLO Models (auto-downloaded if not present)
YOLO_PERSON_MODEL=models/yolov8n.pt
YOLO_POSE_MODEL=models/yolov8n-pose.pt
YOLO_WEAPON_MODEL=models/weapon_yolov8.pt

# Detection Thresholds
DETECTION_CONFIDENCE=0.5
WEAPON_CONFIDENCE=0.7
LOITER_THRESHOLD_SECONDS=15.0
VEHICLE_STATIONARY_THRESHOLD=300.0

# Alert Thresholds
CRITICAL_THREAT_SCORE=0.9
HIGH_THREAT_SCORE=0.7
MEDIUM_THREAT_SCORE=0.5

# Notifications (Optional - for production)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
ALERT_PHONE_NUMBERS=+919876543210

SENDGRID_API_KEY=
ALERT_EMAIL_ADDRESSES=security@example.com

# Video Processing
VIDEO_FPS=10
FRAME_WIDTH=1280
FRAME_HEIGHT=720
MAX_CAMERAS=10

# Storage (Optional - MinIO for video clips)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=trinetra-videos
MINIO_SECURE=False

# Roboflow (Optional - for weapon detection)
ROBOFLOW_API_KEY=your_key_here
ROBOFLOW_WORKSPACE=weapon-detection
ROBOFLOW_PROJECT=weapon-detection-gxgw5
ROBOFLOW_VERSION=1